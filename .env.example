DATABASE_URL=postgres://bella:bella@127.0.0.1:5432/bella
BELLA_API_BIND_ADDR=127.0.0.1:3000
BELLA_API_BASE_URL=http://127.0.0.1:3000
BELLA_PUBLIC_API_URL=http://127.0.0.1:3000
NEXT_PUBLIC_BELLA_PUBLIC_API_URL=http://127.0.0.1:3000
BELLA_WEB_URL=http://127.0.0.1:5173
BELLA_SECURE_COOKIES=false
BELLA_WORKER_POLL_SECONDS=60
# Override for local sandbox testing; production defaults to https://api.openai.com
# OPENAI_BASE_URL=http://127.0.0.1:4010/openai
# Generate with: openssl rand -base64 32
BELLA_CREDENTIAL_ENCRYPTION_KEY=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Optional comma-separated allowlist. When set, only GitHub accounts whose
# primary verified email matches one of these addresses can log in.
BELLA_ALLOWED_GITHUB_EMAILS=
# Optional local Slack integration. All values are required when enabled.
BELLA_SLACK_BOT_TOKEN=
BELLA_SLACK_DEFAULT_CHANNEL_ID=
BELLA_SLACK_ORGANIZATION_ID=
# Shared secret accepted by POST /v1/organizations/:id/webhooks/posthog.
# Prefer per-integration webhook secrets generated from the Integrations UI.
POSTHOG_WEBHOOK_SECRET=
BELLA_ALLOW_GLOBAL_POSTHOG_WEBHOOK_SECRET=false
# Optional read-only PostHog API dogfood ingestion. Use a personal API key with
# query:read access to the selected project.
BELLA_POSTHOG_INGESTION_ENABLED=true
BELLA_POSTHOG_SYNC_INTERVAL_SECONDS=300
BELLA_ALLOWED_POSTHOG_ORIGINS=https://us.posthog.com,https://eu.posthog.com,https://app.posthog.com
POSTHOG_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_API_TOKEN=
# Set true only when Railway/a trusted edge controls forwarded client IP headers.
BELLA_TRUST_PROXY_HEADERS=false
# Required for organization invitations.
RESEND_API_KEY=
BELLA_EMAIL_FROM="Bella <invites@example.com>"
# Production web builds should use a same-origin reverse proxy.
# NEXT_PUBLIC_BELLA_API_BASE_URL=/api

# Optional SDK dogfood settings for Bella-hosted server-side LLM calls.
# BELLA_API_KEY should be a Bella API token for the organization below.
BELLA_API_KEY=
BELLA_ORGANIZATION_ID=
BELLA_PROVIDER_ACCOUNT_ID=
BELLA_PROVIDER=openai
BELLA_SDK_FAIL_OPEN=true
BELLA_SDK_CAPTURE_ERROR_MESSAGE=false
