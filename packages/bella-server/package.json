{
  "name": "@bella/server",
  "version": "0.1.0",
  "description": "Server-side Bella SDK for wrapping LLM calls and recording usage.",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p examples/tsconfig.json"
  },
  "dependencies": {
    "@bella/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~6.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
